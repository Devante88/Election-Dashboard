    "enrich-races": "node scripts/enrich-races.mjs",
    "snapshot-finance": "node scripts/snapshot-finance.mjs",
    "test": "node --test scripts/test/*.test.mjs",
    "build-docs": "node scripts/build-docs.mjs"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "axe-core": "^4.11.4",
